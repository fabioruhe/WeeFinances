generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PerfilFinanceiro {
  POUPADOR
  GASTADOR
  DESLIGADO
  VISIONARIO
}

enum UserPlan {
  FREE
  PREMIUM
}

enum CoupleStatus {
  PENDENTE
  ATIVO
  DESVINCULADO
}

enum DivisaoTipo {
  PROPORCIONAL
  IGUALITARIA
  FIXA
}

enum IncomeTipo {
  FIXO
  VARIAVEL
  EXTRAORDINARIO
}

enum TransactionTipo {
  RECEITA
  DESPESA
}

enum TransactionEscopo {
  INDIVIDUAL
  COMPARTILHADA
}

enum CategoryTipo {
  PADRAO
  CUSTOM
}

enum MerchantRuleSource {
  SISTEMA
  USUARIO
}

enum CategoriaFonte {
  SISTEMA
  USUARIO
  MANUAL
}

enum GoalTipo {
  EMERGENCIA
  VIAGEM
  IMOVEL
  CARRO
  CASAMENTO
  FILHOS
  APOSENTADORIA
  EDUCACAO
  OUTRO
}

enum GoalStatus {
  ATIVA
  ATINGIDA
  PAUSADA
}

enum DebtEstrategia {
  AVALANCHE
  BOLA_DE_NEVE
}

enum DebtStatus {
  ATIVA
  QUITADA
}

enum CardBrand {
  VISA
  MASTERCARD
  ELO
  AMEX
  HIPERCARD
  OUTRO
}

enum SubscriptionFrequency {
  MENSAL
  ANUAL
}

enum InboxStatus {
  PENDENTE
  APROVADO
  IGNORADO
}

enum ImportType {
  OFX
  CSV
  NOTIFICATION
  OPEN_FINANCE
}

enum AssetType {
  RENDA_FIXA
  RENDA_VARIAVEL
  FUNDO
  IMOVEL
  VEICULO
  CRIPTO
  PREVIDENCIA
  POUPANCA
  OUTRO
}

enum DividendType {
  DIVIDENDO
  JCP
  RENDIMENTO
  ALUGUEL
  OUTRO
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id                 String            @id @default(uuid())
  nome               String?
  email              String?           @unique
  emailVerified      DateTime?
  image              String?
  senhaHash          String?
  perfilFinanceiro   PerfilFinanceiro?
  plano              UserPlan          @default(FREE)
  coupleId           String?
  onboardingCompleto Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  couple             Couple?           @relation("UserCurrentCouple", fields: [coupleId], references: [id], onDelete: SetNull)
  coupleAsUserA      Couple[]          @relation("CoupleUserA")
  coupleAsUserB      Couple[]          @relation("CoupleUserB")

  accounts           Account[]
  sessions           Session[]
  incomes            Income[]
  transactions       Transaction[]
  creditCards        CreditCard[]
  additionalCards    CreditCard[]      @relation("CardAdditionalUser")
  installments       Installment[]
  subscriptions      Subscription[]
  inboxItems         InboxItem[]
  appLinks           AppLink[]
  importHistories    ImportHistory[]
  budgets            Budget[]
  goals              Goal[]
  goalContributions  GoalContribution[]
  debts              Debt[]
  debtPayments       DebtPayment[]
  checkIns           CheckIn[]
  assets             Asset[]
  dividendEntries    DividendEntry[]
  fixedExpenses      FixedExpense[]

  @@index([coupleId])
}

// ─── Couple ──────────────────────────────────────────────────────────────────

model Couple {
  id          String       @id @default(uuid())
  userAId     String
  userBId     String?
  divisaoTipo DivisaoTipo?
  inviteCode  String       @unique
  status      CoupleStatus @default(PENDENTE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userA       User         @relation("CoupleUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User?        @relation("CoupleUserB", fields: [userBId], references: [id], onDelete: SetNull)
  members     User[]       @relation("UserCurrentCouple")

  transactions    Transaction[]
  creditCards     CreditCard[]
  installments    Installment[]
  subscriptions   Subscription[]
  inboxItems      InboxItem[]
  appLinks        AppLink[]
  importHistories ImportHistory[]
  budgets         Budget[]
  goals           Goal[]
  debts           Debt[]
  checkIns        CheckIn[]
  assets          Asset[]
  dividendEntries DividendEntry[]
  fixedExpenses   FixedExpense[]
  categories      Category[]

  @@index([userAId])
  @@index([userBId])
  @@index([inviteCode])
}

// ─── Income ──────────────────────────────────────────────────────────────────

model Income {
  id            String     @id @default(uuid())
  userId        String
  valor         Decimal    @db.Decimal(12, 2)
  tipo          IncomeTipo
  descricao     String?
  mesReferencia DateTime   @db.Date
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mesReferencia])
}

// ─── Category ────────────────────────────────────────────────────────────────

model Category {
  id            String        @id @default(uuid())
  nome          String
  icone         String?
  tipo          CategoryTipo  @default(PADRAO)
  coupleId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  couple        Couple?       @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  subcategories Subcategory[]
  transactions  Transaction[]
  budgets       Budget[]
  installments  Installment[]
  subscriptions Subscription[]
  merchantRules MerchantRule[]
  fixedExpenses FixedExpense[]

  @@index([coupleId])
}

// ─── Subcategory ─────────────────────────────────────────────────────────────

model Subcategory {
  id          String        @id @default(uuid())
  categoriaId String
  nome        String
  icone       String?
  ordem       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category      Category      @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  merchantRules MerchantRule[]

  @@index([categoriaId])
}

// ─── MerchantRule ────────────────────────────────────────────────────────────

model MerchantRule {
  id             String             @id @default(uuid())
  coupleId       String?
  keyword        String
  categoriaId    String
  subcategoriaId String?
  source         MerchantRuleSource @default(SISTEMA)
  hitCount       Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  categoria    Category    @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  subcategoria Subcategory? @relation(fields: [subcategoriaId], references: [id], onDelete: SetNull)

  @@index([coupleId])
  @@index([keyword])
}

// ─── Transaction ─────────────────────────────────────────────────────────────

model Transaction {
  id             String            @id @default(uuid())
  userId         String
  coupleId       String?
  valor          Decimal           @db.Decimal(12, 2)
  tipo           TransactionTipo
  escopo         TransactionEscopo @default(INDIVIDUAL)
  categoriaId    String?
  subcategoriaId String?
  descricao      String?
  data           DateTime          @db.Date
  reviewed       Boolean           @default(false)
  anomalia       Boolean           @default(false)
  categoriaFonte CategoriaFonte?
  deletedAt      DateTime?
  creditCardId   String?
  installmentId  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple       Couple?      @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  categoria    Category?    @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  subcategoria Subcategory? @relation(fields: [subcategoriaId], references: [id], onDelete: SetNull)
  creditCard   CreditCard?  @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  installment  Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  inboxItem    InboxItem?

  @@index([userId])
  @@index([coupleId])
  @@index([data])
  @@index([userId, data])
  @@index([coupleId, data])
  @@index([creditCardId])
  @@index([installmentId])
}

// ─── CreditCard ──────────────────────────────────────────────────────────────

model CreditCard {
  id                String     @id @default(uuid())
  userId            String
  coupleId          String?
  apelido           String
  bandeira          CardBrand  @default(OUTRO)
  ultimos4Digitos   String?    @db.VarChar(4)
  limiteTotal       Decimal?   @db.Decimal(12, 2)
  diaFechamento     Int?
  diaVencimento     Int?
  corHex            String?
  ativo             Boolean    @default(true)
  isAdicional       Boolean    @default(false)
  adicionalUserId   String?
  belvoLinkId       String?
  belvoInstitution  String?
  lastSyncAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple        Couple?       @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  adicionalUser User?         @relation("CardAdditionalUser", fields: [adicionalUserId], references: [id], onDelete: SetNull)

  transactions    Transaction[]
  installments    Installment[]
  subscriptions   Subscription[]
  inboxItems      InboxItem[]
  appLinks        AppLink[]
  importHistories ImportHistory[]

  @@index([userId])
  @@index([coupleId])
  @@index([diaFechamento])
  @@index([diaVencimento])
}

// ─── Installment ─────────────────────────────────────────────────────────────

model Installment {
  id                String            @id @default(uuid())
  creditCardId      String
  userId            String
  coupleId          String?
  descricao         String
  valorTotal        Decimal           @db.Decimal(12, 2)
  valorParcela      Decimal           @db.Decimal(12, 2)
  parcelasTotal     Int
  parcelasPagas     Int               @default(0)
  categoriaId       String?
  escopo            TransactionEscopo @default(INDIVIDUAL)
  dataCompra        DateTime          @db.Date
  primeiraParcela   DateTime          @db.Date
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  creditCard   CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple       Couple?    @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  categoria    Category?  @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([userId])
  @@index([coupleId])
  @@index([creditCardId])
}

// ─── Subscription ────────────────────────────────────────────────────────────

model Subscription {
  id           String                @id @default(uuid())
  userId       String
  coupleId     String?
  creditCardId String?
  nome         String
  valor        Decimal               @db.Decimal(12, 2)
  categoriaId  String?
  frequencia   SubscriptionFrequency @default(MENSAL)
  ativa        Boolean               @default(true)
  detectadaAuto Boolean              @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple     Couple?     @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  categoria  Category?   @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([coupleId])
}

// ─── InboxItem ───────────────────────────────────────────────────────────────

model InboxItem {
  id                  String      @id @default(uuid())
  userId              String
  coupleId            String?
  creditCardId        String?
  valor               Decimal     @db.Decimal(12, 2)
  descricao           String
  tipoTransacao       String?
  appOrigem           String?
  packageName         String?
  categoriaSugeridaId String?
  status              InboxStatus @default(PENDENTE)
  transactionId       String?     @unique
  timestamp           DateTime
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple        Couple?      @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  creditCard    CreditCard?  @relation(fields: [creditCardId], references: [id], onDelete: SetNull)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([coupleId])
  @@index([status])
}

// ─── AppLink ─────────────────────────────────────────────────────────────────

model AppLink {
  id           String     @id @default(uuid())
  userId       String
  coupleId     String?
  packageName  String
  creditCardId String
  appNome      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple     Couple?    @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  creditCard CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Cascade)

  @@unique([userId, packageName])
  @@index([coupleId])
}

// ─── ImportHistory ───────────────────────────────────────────────────────────

model ImportHistory {
  id               String     @id @default(uuid())
  userId           String
  coupleId         String?
  creditCardId     String
  tipo             ImportType
  arquivoNome      String?
  totalImportadas  Int        @default(0)
  totalDuplicadas  Int        @default(0)
  createdAt        DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple     Couple?    @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  creditCard CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([coupleId])
}

// ─── Budget ──────────────────────────────────────────────────────────────────

model Budget {
  id            String   @id @default(uuid())
  userId        String
  coupleId      String?
  categoriaId   String
  limiteMensal  Decimal  @db.Decimal(12, 2)
  mesReferencia DateTime @db.Date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple    Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  categoria Category @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@unique([userId, categoriaId, mesReferencia])
  @@index([userId])
  @@index([coupleId])
  @@index([mesReferencia])
}

// ─── Goal ────────────────────────────────────────────────────────────────────

model Goal {
  id             String     @id @default(uuid())
  userId         String
  coupleId       String?
  nome           String
  valorAlvo      Decimal    @db.Decimal(12, 2)
  valorAtual     Decimal    @default(0) @db.Decimal(12, 2)
  prazo          DateTime?  @db.Date
  tipo           GoalTipo   @default(OUTRO)
  status         GoalStatus @default(ATIVA)
  contribuicaoA  Decimal?   @db.Decimal(12, 2)
  contribuicaoB  Decimal?   @db.Decimal(12, 2)
  prioridade     Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple        Couple?            @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  contributions GoalContribution[]

  @@index([userId])
  @@index([coupleId])
}

// ─── GoalContribution ────────────────────────────────────────────────────────

model GoalContribution {
  id        String   @id @default(uuid())
  goalId    String
  userId    String
  valor     Decimal  @db.Decimal(12, 2)
  data      DateTime @db.Date
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([userId])
}

// ─── Debt ────────────────────────────────────────────────────────────────────

model Debt {
  id            String            @id @default(uuid())
  userId        String
  coupleId      String?
  nome          String
  valorTotal    Decimal           @db.Decimal(12, 2)
  valorRestante Decimal           @db.Decimal(12, 2)
  parcelasTotal Int?
  parcelasPagas Int               @default(0)
  taxaJuros     Decimal?          @db.Decimal(5, 2)
  vencimentoDia Int?
  estrategia    DebtEstrategia    @default(AVALANCHE)
  escopo        TransactionEscopo @default(INDIVIDUAL)
  status        DebtStatus        @default(ATIVA)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple   Couple?       @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  payments DebtPayment[]

  @@index([userId])
  @@index([coupleId])
  @@index([status])
}

// ─── DebtPayment ─────────────────────────────────────────────────────────────

model DebtPayment {
  id        String   @id @default(uuid())
  debtId    String
  userId    String
  valor     Decimal  @db.Decimal(12, 2)
  data      DateTime @db.Date
  createdAt DateTime @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@index([userId])
}

// ─── CheckIn ─────────────────────────────────────────────────────────────────

model CheckIn {
  id           String   @id @default(uuid())
  coupleId     String?
  userId       String?
  data         DateTime @db.Date
  resumoJson   Json?
  sentimentoA  Int
  sentimentoB  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  couple Couple? @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([coupleId])
  @@index([userId])
  @@index([data])
}

// ─── Asset ───────────────────────────────────────────────────────────────────

model Asset {
  id             String    @id @default(uuid())
  userId         String
  coupleId       String?
  nome           String
  tipo           AssetType
  instituicao    String?
  ticker         String?
  valorAtual     Decimal   @db.Decimal(14, 2)
  valorInvestido Decimal   @db.Decimal(14, 2)
  dataAquisicao  DateTime? @db.Date
  notas          String?
  ativo          Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple    Couple?        @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  snapshots AssetSnapshot[]
  dividends DividendEntry[]

  @@index([userId])
  @@index([coupleId])
}

// ─── AssetSnapshot ───────────────────────────────────────────────────────────

model AssetSnapshot {
  id            String   @id @default(uuid())
  assetId       String
  valor         Decimal  @db.Decimal(14, 2)
  mesReferencia DateTime @db.Date
  createdAt     DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([mesReferencia])
}

// ─── DividendEntry ───────────────────────────────────────────────────────────

model DividendEntry {
  id            String       @id @default(uuid())
  userId        String
  coupleId      String?
  assetId       String?
  valor         Decimal      @db.Decimal(12, 2)
  mesReferencia DateTime     @db.Date
  descricao     String?
  tipo          DividendType @default(DIVIDENDO)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple Couple? @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  asset  Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([coupleId])
  @@index([mesReferencia])
}

// ─── FixedExpense ────────────────────────────────────────────────────────────

model FixedExpense {
  id          String            @id @default(uuid())
  userId      String
  coupleId    String?
  nome        String
  valorMedio  Decimal           @db.Decimal(12, 2)
  categoriaId String
  escopo      TransactionEscopo @default(INDIVIDUAL)
  prioridade  Int               @default(0)
  ativo       Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple    Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  categoria Category @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([coupleId])
}

// ─── NextAuth Models ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
